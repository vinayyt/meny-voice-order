# ─── Anthropic Claude API ─────────────────────────────────────────
# Get your key at: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ─── Email sending via Resend ─────────────────────────────────────
# Get your key at: https://resend.com (free tier: 100 emails/day)
RESEND_API_KEY=re_your-key-here

# ─── Order destination email ──────────────────────────────────────
# Where orders should be sent (e.g. your store's email)
ORDER_EMAIL=orders@yourstore.no

# ─── From email (must be a verified domain in Resend) ────────────
# For testing, use Resend's default: onboarding@resend.dev
FROM_EMAIL=onboarding@resend.dev
